---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ChefMate V2 | Vincent Hu" description="图RAG 智能食谱问答系统 — GraphRAG 技术演示">
  <div class="mx-auto flex max-w-5xl flex-col gap-8">
    <!-- Header -->
    <div class="hero-panel animate-slide-enter overflow-hidden rounded-[2rem] border border-black/8 p-6 shadow-[0_24px_80px_rgba(15,23,42,0.08)] dark:border-white/10 dark:shadow-[0_24px_80px_rgba(0,0,0,0.28)] md:p-7">
      <div class="flex items-center gap-3 mb-3">
        <span class="inline-flex items-center gap-1.5 rounded-full border border-violet-500/20 bg-violet-500/8 px-2.5 py-0.5 text-xs font-mono tracking-[0.22em] text-violet-700 dark:text-violet-300">
          GraphRAG DEMO
        </span>
        <span class="text-xs opacity-35">Neo4j · Milvus · DeepSeek V4 · 智能路由</span>
      </div>
      <div class="grid gap-5 lg:grid-cols-[auto_1fr] lg:items-center">
        <h1 class="text-3xl font-bold font-condensed tracking-tight md:text-4xl shrink-0">
          ChefMate V2
        </h1>
        <div class="text-sm leading-6 opacity-55 lg:border-l lg:border-black/10 lg:pl-5 dark:lg:border-white/10">
          基于图RAG的下一代食谱问答系统，引入知识图谱推理能力。<br class="hidden sm:block" />
          <span class="opacity-40 text-xs mt-1 block">🚧 后端开发中，前端演示已就绪。API 尚未连接。</span>
        </div>
      </div>
    </div>

    <!-- Main grid: Chat + Strategy Panel -->
    <div class="grid gap-6 lg:grid-cols-[2fr_1fr] items-start">
      <!-- Left: Chat -->
      <div class="flex flex-col gap-4">
        <div class="flex flex-col gap-5 h-[480px] overflow-y-auto rounded-[1.75rem] border border-black/8 bg-white/52 p-6 dark:border-white/10 dark:bg-white/[0.03]">
          <div class="flex items-start gap-3">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-violet-500/15 text-base dark:bg-violet-500/20">🕸️</div>
            <div class="rounded-2xl rounded-tl-md bg-black/[0.03] px-4 py-3 text-sm leading-relaxed dark:bg-white/[0.05]">
              你好！我是 <strong>ChefMate V2</strong>，基于图RAG的智能食谱助手。<br/>
              相比 V1，我现在能理解食材关系、发现相似菜品、进行多跳推理。<br/><br/>
              试试问我「<strong>哪些川菜用了鸡肉和花生</strong>」或「<strong>有没有类似宫保鸡丁但更简单的</strong>」。
            </div>
          </div>
        </div>

        <form class="flex gap-3 opacity-50 pointer-events-none">
          <input type="text" placeholder="后端开发中，暂不可用…" disabled
            class="flex-1 rounded-xl border border-black/8 bg-white/62 px-5 py-3 text-sm outline-none disabled:opacity-40" />
          <button type="submit" disabled
            class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-violet-500 text-white opacity-40">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </form>
      </div>

      <!-- Right: Strategy + Knowledge Graph -->
      <div class="flex flex-col gap-5">
        <!-- Strategy Panel -->
        <div class="rounded-[1.75rem] border border-black/8 bg-white/52 p-5 dark:border-white/10 dark:bg-white/[0.03]">
          <h3 class="text-xs font-mono tracking-[0.18em] opacity-35 mb-4">STRATEGY</h3>
          <div class="space-y-3">
            <div class="flex items-center gap-3 rounded-xl border border-violet-500/20 bg-violet-500/[0.04] p-3">
              <span class="text-lg">🔍</span>
              <div>
                <div class="text-xs font-medium opacity-70">传统混合检索</div>
                <div class="text-[11px] opacity-35">Milvus + BM25 + RRF 融合</div>
              </div>
              <span class="ml-auto text-[10px] font-mono opacity-25">简单查询</span>
            </div>
            <div class="flex items-center gap-3 rounded-xl border border-violet-500/20 bg-violet-500/[0.04] p-3">
              <span class="text-lg">🔄</span>
              <div>
                <div class="text-xs font-medium opacity-70">组合检索</div>
                <div class="text-[11px] opacity-35">传统 + 图 RAG 融合</div>
              </div>
              <span class="ml-auto text-[10px] font-mono opacity-25">中等复杂</span>
            </div>
            <div class="flex items-center gap-3 rounded-xl border border-violet-500/30 bg-violet-500/[0.08] p-3">
              <span class="text-lg">🕸️</span>
              <div>
                <div class="text-xs font-medium opacity-70">图RAG 检索</div>
                <div class="text-[11px] opacity-35">Neo4j 多跳推理</div>
              </div>
              <span class="ml-auto text-[10px] font-mono opacity-25">复杂推理</span>
            </div>
          </div>
          <div class="mt-4 pt-4 border-t border-black/6 dark:border-white/6">
            <div class="text-[10px] opacity-30 mb-2">降级链</div>
            <div class="flex items-center gap-1.5 text-[10px] font-mono opacity-20">
              <span>图RAG</span><span>→</span><span>组合</span><span>→</span><span>传统混合</span>
            </div>
          </div>
        </div>

        <!-- Knowledge Graph Preview -->
        <div class="rounded-[1.75rem] border border-black/8 bg-white/52 p-5 dark:border-white/10 dark:bg-white/[0.03]">
          <h3 class="text-xs font-mono tracking-[0.18em] opacity-35 mb-4">KNOWLEDGE GRAPH</h3>
          <div class="rounded-xl border border-dashed border-black/10 bg-black/[0.01] p-4 dark:border-white/10 dark:bg-white/[0.01]">
            <!-- Placeholder for knowledge graph visualization -->
            <div class="flex flex-col items-center gap-3 py-4">
              <div class="flex items-center gap-2">
                <div class="h-3 w-3 rounded-full bg-violet-400"></div>
                <div class="h-0.5 w-8 bg-violet-300/30"></div>
                <div class="h-3 w-3 rounded-full bg-amber-400"></div>
                <div class="h-0.5 w-8 bg-violet-300/30"></div>
                <div class="h-3 w-3 rounded-full bg-emerald-400"></div>
              </div>
              <div class="flex gap-4 text-[10px] opacity-30">
                <span>菜谱</span><span>食材</span><span>步骤</span>
              </div>
              <div class="text-[10px] opacity-20 mt-2">
                Neo4j 图数据库 · 362 菜谱节点 · 500+ 食材节点
              </div>
            </div>
          </div>
        </div>

        <!-- Metrics Placeholder -->
        <div class="rounded-[1.75rem] border border-black/8 bg-white/52 p-5 dark:border-white/10 dark:bg-white/[0.03]">
          <h3 class="text-xs font-mono tracking-[0.18em] opacity-35 mb-4">RAG METRICS</h3>
          <div class="grid gap-3 grid-cols-2">
            <div class="rounded-xl border border-black/6 bg-black/[0.015] p-3 dark:border-white/8 dark:bg-white/[0.02]">
              <div class="text-[10px] opacity-35 mb-1">路由策略</div>
              <div class="text-sm opacity-25">—</div>
            </div>
            <div class="rounded-xl border border-black/6 bg-black/[0.015] p-3 dark:border-white/8 dark:bg-white/[0.02]">
              <div class="text-[10px] opacity-35 mb-1">图遍历深度</div>
              <div class="text-sm opacity-25">—</div>
            </div>
            <div class="rounded-xl border border-black/6 bg-black/[0.015] p-3 dark:border-white/8 dark:bg-white/[0.02]">
              <div class="text-[10px] opacity-35 mb-1">检索来源</div>
              <div class="text-sm opacity-25">—</div>
            </div>
            <div class="rounded-xl border border-black/6 bg-black/[0.015] p-3 dark:border-white/8 dark:bg-white/[0.02]">
              <div class="text-[10px] opacity-35 mb-1">子图节点</div>
              <div class="text-sm opacity-25">—</div>
            </div>
          </div>
        </div>

        <!-- Status -->
        <div class="rounded-xl border border-amber-500/20 bg-amber-500/[0.04] px-3 py-3 text-xs opacity-50">
          ⚠️ 后端 GraphRAG 引擎开发中，前端为静态演示
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .msg-content h1 { font-size: 1.1rem; font-weight: 700; margin: 0.6em 0 0.3em; }
  .msg-content h2 { font-size: 1rem; font-weight: 650; margin: 0.5em 0 0.25em; padding-bottom: 0.2em; border-bottom: 1px solid rgb(0 0 0 / 0.06); }
</style>
