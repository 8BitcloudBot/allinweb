<script is:inline src="/marked.min.js"></script>

<script>
  const form = document.getElementById('chat-form');
  const input = document.getElementById('chat-input');
  const messages = document.getElementById('chat-messages');
  const sendBtn = document.getElementById('chat-send');
  const metricsContent = document.getElementById('metrics-content');
  const statusText = document.getElementById('status-text');

  function updateStatus(state) {
    if (!statusText) return;
    const el = document.getElementById('metrics-status');
    if (state === 'loading') {
      statusText.textContent = '正在检索分析…';
      el.style.opacity = '0.75';
    } else if (state === 'ready') {
      statusText.textContent = '检索分析结果已生成 ↓';
      el.style.opacity = '0.8';
    } else {
      statusText.textContent = '检索分析结果在页面下方生成';
      el.style.opacity = '0.55';
    }
  }

  // ─── Tooltip system (JS-based, bypasses Astro scoping issues) ───
  let activeTooltip = null;

  function createTooltip(text) {
    const tip = document.createElement('div');
    tip.className = 'tooltip-popup';
    tip.textContent = text;
    tip.style.cssText = `
      position: fixed; z-index: 9999; pointer-events: none;
      background: rgb(30 30 35); color: #fff;
      font-size: 11px; font-weight: 400; line-height: 1.45;
      max-width: 200px; padding: 6px 10px; border-radius: 6px;
      text-align: center; opacity: 0;
      transition: opacity 0.15s;
    `;
    document.body.appendChild(tip);

    // Arrow
    const arrow = document.createElement('div');
    arrow.style.cssText = `
      position: fixed; z-index: 9999; pointer-events: none;
      width: 0; height: 0;
      border-left: 4px solid transparent;
      border-right: 4px solid transparent;
      border-top: 4px solid rgb(30 30 35);
      opacity: 0; transition: opacity 0.15s;
    `;
    document.body.appendChild(arrow);

    // Dark mode support
    const isDark = document.documentElement.classList.contains('dark');
    if (isDark) {
      tip.style.background = '#e8e8e8';
      tip.style.color = '#1a1a1a';
      arrow.style.borderTopColor = '#e8e8e8';
    }

    return { tip, arrow };
  }

  function positionTooltip(tt, el) {
    const rect = el.getBoundingClientRect();
    const cx = rect.left + rect.width / 2;
    const top = rect.top - 8;

    tt.tip.style.left = cx + 'px';
    tt.tip.style.bottom = (window.innerHeight - top) + 'px';
    tt.tip.style.transform = 'translate(-50%, -100%)';

    tt.arrow.style.left = cx + 'px';
    tt.arrow.style.bottom = (window.innerHeight - top + 4) + 'px';
    tt.arrow.style.transform = 'translateX(-50%)';
  }

  function showTooltip(el) {
    const title = el.getAttribute('data-title');
    if (!title) return;
    if (activeTooltip) hideTooltip();
    activeTooltip = createTooltip(title);
    positionTooltip(activeTooltip, el);
    requestAnimationFrame(() => {
      if (activeTooltip) {
        activeTooltip.tip.style.opacity = '1';
        activeTooltip.arrow.style.opacity = '1';
      }
    });
  }

  function hideTooltip() {
    if (activeTooltip) {
      activeTooltip.tip.remove();
      activeTooltip.arrow.remove();
      activeTooltip = null;
    }
  }

  document.addEventListener('mouseover', (e) => {
    const dot = e.target.closest('.info-dot');
    if (dot && dot.getAttribute('data-title')) {
      showTooltip(dot);
    }
  }, true);

  document.addEventListener('mouseout', (e) => {
    const dot = e.target.closest('.info-dot');
    if (dot) hideTooltip();
  }, true);

  // Cleanup on mutation (when metrics panel is replaced)
  const metricsObserver = new MutationObserver(() => {
    hideTooltip();
  });
  metricsObserver.observe(metricsContent, { childList: true, subtree: true });

  // ─── Suggested queries ───
  document.querySelectorAll('.prompt-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const q = chip.getAttribute('data-query');
      if (!q) return;
      // Detect which section the chip is in
      if (chip.closest('#demo-graphrag')) {
        graphragInput.value = q;
        graphragInput.classList.add('ring-2', 'ring-violet-500/40');
        setTimeout(() => graphragInput.classList.remove('ring-2', 'ring-violet-500/40'), 600);
        graphragInput.focus();
      } else {
        input.value = q;
        input.classList.add('ring-2', 'ring-primary/40');
        setTimeout(() => input.classList.remove('ring-2', 'ring-primary/40'), 600);
        input.focus();
      }
    });
  });

  // ─── Chat ───
  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function renderMarkdown(text) {
    if (typeof marked !== 'undefined') {
      return marked.parse(text, { breaks: true });
    }
    return text.replace(/\n/g, '<br/>');
  }
  const formatMarkdown = text => typeof marked !== 'undefined' ? marked.parse(text, { breaks: true }) : text.replace(/\n/g, '<br/>');
  window.formatMarkdown = formatMarkdown;

  function addMessage(role, content, html = false) {
    const div = document.createElement('div');
    const isUser = role === 'user';

    if (isUser) {
      div.className = 'flex items-start gap-3 justify-end';
      div.innerHTML =
        `<div class="rounded-2xl rounded-tr-md bg-primary px-4 py-3 text-sm leading-relaxed text-white max-w-[85%]">${escapeHtml(content)}</div>
         <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-primary/15 text-base dark:bg-primary/20">👤</div>`;
    } else {
      div.className = 'flex items-start gap-3';
      div.innerHTML =
        `<div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-amber-500/15 text-base dark:bg-amber-500/20">🧑‍🍳</div>
         <div class="rounded-2xl rounded-tl-md bg-black/[0.03] px-4 py-3 text-sm leading-relaxed dark:bg-white/[0.05] max-w-[85%] msg-content">${html ? content : escapeHtml(content)}</div>`;
    }
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
  }

  function updateMetrics(metrics) {
    if (!metrics) return;
    let sourcesHtml = '';
    if (metrics.sources && metrics.sources.length) {
      sourcesHtml = metrics.sources.map(s => {
        const vp = Math.round((s.vec_score || 0) * 100);
        const bp = Math.round((s.bm25_score || 0) * 100);
        return `<div class="rounded-xl border border-black/6 bg-black/[0.02] p-3 dark:border-white/8 dark:bg-white/[0.02]">
           <div class="flex items-center justify-between mb-2">
             <span class="text-sm font-medium">${escapeHtml(s.dish_name || '')}</span>
             <span class="text-xs opacity-35">${escapeHtml(s.category || '')}</span>
           </div>
           <div class="space-y-1.5">
             <div class="flex items-center justify-between text-xs opacity-45">
               <span>语义匹配</span>
               <span class="font-mono">${vp}%</span>
             </div>
             <div class="score-bar"><div class="score-bar-fill score-bar-vec" style="width:${vp}%"></div></div>
             <div class="flex items-center justify-between text-xs opacity-45">
               <span>关键词匹配</span>
               <span class="font-mono">${bp > 0 ? bp + '%' : 'N/A'}</span>
             </div>
             <div class="score-bar"><div class="score-bar-fill score-bar-bm25" style="width:${Math.max(bp, 2)}%"></div></div>
             <div class="text-xs opacity-30 mt-1">命中 ${s.match_count || 0} 个子块</div>
           </div>
         </div>`;
      }).join('');
    }
    metricsContent.innerHTML = `
        <div class="rounded-xl border border-black/6 bg-black/[0.015] p-3 dark:border-white/8 dark:bg-white/[0.02]">
           <div class="flex items-center gap-0.5 text-[10px] opacity-35 mb-1.5">
             路由类型
             <span class="info-dot inline-flex" data-title="系统自动判断的查询类型：详细指导=步骤教学，列表推荐=菜品列表，通用问答=知识解答"></span>
           </div>
           <div class="text-sm font-medium">${metrics.query?.route_type || '—'}</div>
         </div>
         ${metrics.elapsed_ms ? `<div class="rounded-xl border border-black/6 bg-black/[0.015] p-3 dark:border-white/8 dark:bg-white/[0.02]">
           <div class="flex items-center gap-0.5 text-[10px] opacity-35 mb-1.5">
             耗时
             <span class="info-dot inline-flex" data-title="从接收问题到返回答案的端到端时间，包含检索和 LLM 生成"></span>
           </div>
          <div class="text-sm font-mono font-medium">${metrics.elapsed_ms}ms</div>
        </div>` : ''}
        <div class="rounded-xl border border-black/6 bg-black/[0.015] p-3 dark:border-white/8 dark:bg-white/[0.02]">
          <div class="text-[10px] opacity-35 mb-1.5">检索命中</div>
          <div class="text-sm font-mono font-medium">${metrics.sources?.length || 0} 菜谱</div>
        </div>
        ${sourcesHtml ? `<div class="col-span-full mt-2">
          <div class="flex items-center gap-0.5 text-[10px] opacity-35 mb-2">
            检索来源 · 发送给 LLM 的菜谱
            <span class="info-dot inline-flex" data-title="RAG 检索到的相关菜谱，按综合得分从高到低排列。紫色=语义向量匹配，橙色=关键词BM25匹配（中文查询通常为N/A），命中子块数=该菜谱有多少片段被送入 LLM">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            </span>
          </div>
          <div class="grid gap-3 lg:grid-cols-2 xl:grid-cols-3">
            ${sourcesHtml}
          </div>
        </div>` : ''}
    `;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const query = input.value.trim();
    if (!query) return;

    addMessage('user', query);
    input.value = '';
    sendBtn.disabled = true;
    updateStatus('loading');

    const loadingDiv = document.createElement('div');
    loadingDiv.className = 'flex items-start gap-3';
    loadingDiv.innerHTML = `<div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-amber-500/15 text-base dark:bg-amber-500/20">🧑‍🍳</div>
      <div class="rounded-2xl rounded-tl-md bg-black/[0.03] px-4 py-3 text-sm dark:bg-white/[0.05]">
        <span class="opacity-40">思考中<span class="animate-pulse">...</span></span>
      </div>`;
    messages.appendChild(loadingDiv);
    messages.scrollTop = messages.scrollHeight;

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query }),
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      loadingDiv.remove();
      addMessage('assistant', renderMarkdown(data.answer || ''), true);
      if (data.metrics) {
        updateMetrics(data.metrics);
        updateStatus('ready');
      } else {
        metricsContent.innerHTML = '<div class="text-sm opacity-40 col-span-full">等待查询...</div>';
        updateStatus('idle');
      }
    } catch (err) {
      loadingDiv.remove();
      addMessage('assistant', '❌ 请求失败: ' + err.message);
    } finally {
      sendBtn.disabled = false;
      input.focus();
    }
  });
</script>

<script>
  // Version tab switching
  const tabRag = document.getElementById('tab-rag');
  const tabGraphrag = document.getElementById('tab-graphrag');
  const demoRag = document.getElementById('demo-rag');
  const demoGraphrag = document.getElementById('demo-graphrag');

  function switchTab(active) {
    if (active === 'rag') {
      demoRag.style.display = '';
      demoGraphrag.style.display = 'none';
      tabRag.className = tabRag.className.replace(/border-transparent/, 'border-amber-500/40').replace(/bg-black.*?\]/, 'bg-amber-500/[0.06]');
      tabGraphrag.className = tabGraphrag.className.replace(/border-violet-500\/40/, 'border-transparent').replace(/bg-violet-500.*?\]/, 'bg-black/[0.02] dark:bg-white/[0.02]');
    } else {
      demoRag.style.display = 'none';
      demoGraphrag.style.display = '';
      tabGraphrag.className = tabGraphrag.className.replace(/border-transparent/, 'border-violet-500/40').replace(/bg-black.*?\]/, 'bg-violet-500/[0.06]');
      tabRag.className = tabRag.className.replace(/border-amber-500\/40/, 'border-transparent').replace(/bg-amber-500.*?\]/, 'bg-black/[0.02] dark:bg-white/[0.02]');
    }
  }

  tabRag.addEventListener('click', () => switchTab('rag'));
  tabGraphrag.addEventListener('click', () => switchTab('graphrag'));

  if (window.location.hash === '#graphrag') switchTab('graphrag');

  // GraphRAG chat
  const graphragInput = document.getElementById('graphrag-input');
  const graphragSendBtn = document.getElementById('graphrag-send-btn');
  const graphragChat = document.querySelector('#demo-graphrag .overflow-y-auto');
  const graphragStrategyCards = document.querySelectorAll('#demo-graphrag .STRATEGY ~ div > div[class*=\"rounded-xl\"]');

  const GRAPHRAG_API = '/api/graphchat';

  const STRATEGY_NAMES = {
    hybrid_traditional: '🔍 传统混合检索',
    graph_rag: '🕸️ 图 RAG 检索',
    combined: '🔄 组合检索',
  };

  async function sendGraphragQuery(query) {
    if (!query.trim()) return;

    updateGraphragStatus('loading');

    const userBubble = document.createElement('div');
    userBubble.className = 'flex items-start gap-3 justify-end';
    userBubble.innerHTML = `<div class="rounded-2xl rounded-tr-md bg-violet-500/10 px-4 py-3 text-sm max-w-[80%]">${query}</div>`;
    graphragChat.appendChild(userBubble);

    const aiBubble = document.createElement('div');
    aiBubble.className = 'flex items-start gap-3';
    aiBubble.innerHTML = `<div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-violet-500/15 text-base dark:bg-violet-500/20">🕸️</div><div class="rounded-2xl rounded-tl-md bg-black/[0.03] px-4 py-3 text-sm leading-relaxed dark:bg-white/[0.05] msg-content"><span class="inline-block animate-pulse">思考中…</span></div>`;
    graphragChat.appendChild(aiBubble);
    graphragChat.scrollTop = graphragChat.scrollHeight;
    graphragInput.value = '';
    graphragSendBtn.disabled = true;

    try {
      const resp = await fetch(GRAPHRAG_API, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query }),
      });
      const data = await resp.json();
      const msgDiv = aiBubble.querySelector('.msg-content');

      const answer = data.answer || '';
      const ri = data.routing_info || {};
      const strategy = ri.strategy || '';
      const label = STRATEGY_NAMES[strategy] || strategy;
      const depth = (data.graph_metrics || {}).traversal_depth || 0;
      const nodes = (data.graph_metrics || {}).node_count || 0;
      const latency = ((data.metrics || {}).latency_seconds || 0).toFixed(1);

      const badgeHtml = strategy ? `<div class="mb-3 flex items-center gap-2 text-[11px] opacity-60"><span class="rounded-md bg-violet-500/10 px-2 py-0.5 font-medium text-violet-600 dark:text-violet-400">${label}</span>${depth ? `<span class=\"opacity-50\">depth=${depth}</span>` : ''}${nodes ? `<span class=\"opacity-50\">${nodes} nodes</span>` : ''}<span class=\"ml-auto opacity-40 font-mono\">${latency}s</span></div>` : '';

      msgDiv.innerHTML = badgeHtml + (window.formatMarkdown ? window.formatMarkdown(answer) : answer.replace(/\n/g, '<br/>'));
      updateGraphragMetrics(data);
      updateGraphragStatus('ready');
    } catch (e) {
      updateGraphragStatus('error');
      aiBubble.querySelector('.msg-content').textContent = 'GraphRAG 引擎未连接（需要启动后端服务）';
    } finally {
      graphragSendBtn.disabled = false;
    }
    graphragChat.scrollTop = graphragChat.scrollHeight;
  }

  function updateGraphragStatus(state) {
    const el = document.getElementById('graphrag-status');
    const text = document.getElementById('graphrag-status-text');
    if (!el || !text) return;
    if (state === 'loading') {
      text.textContent = '正在检索分析…';
      el.style.opacity = '0.75';
    } else if (state === 'ready') {
      text.textContent = '检索分析结果已生成 ↓';
      el.style.opacity = '0.8';
    } else if (state === 'error') {
      text.textContent = '检索失败，请检查后端服务';
      el.style.opacity = '0.75';
    } else {
      text.textContent = '检索分析结果在页面下方生成';
      el.style.opacity = '0.55';
    }
  }

  function updateGraphragMetrics(data) {
    const set = (id, val, fmt) => {
      const el = document.getElementById(id);
      if (el) { el.textContent = val != null && val !== '' ? (fmt ? fmt(val) : val) : '—'; el.style.opacity = val != null && val !== '' ? '0.8' : '0.2'; }
    };
    const ri = data.routing_info || {};
    const gm = data.graph_metrics || {};
    const m = data.metrics || {};

    set('gm-route-strategy', STRATEGY_NAMES[ri.strategy] || ri.strategy);
    set('gm-search-source', gm.search_source || ri.strategy);
    set('gm-retrieval-count', m.retrieval_count);
    set('gm-latency', m.latency_seconds != null ? m.latency_seconds + 's' : null);
    set('gm-node-count', gm.node_count);
    set('gm-depth', gm.traversal_depth);
    set('gm-confidence', m.confidence_score != null ? (m.confidence_score * 100).toFixed(0) + '%' : null);
    set('gm-intensity', ri.relationship_intensity != null ? ri.relationship_intensity.toFixed(2) : null);

    // Highlight active strategy card
    const strategy = ri.strategy || '';
    const reasoningEl = document.getElementById('gs-reasoning');
    document.querySelectorAll('#demo-graphrag [data-strategy]').forEach(card => {
      const s = card.getAttribute('data-strategy');
      const active = s === strategy;
      card.style.borderColor = active ? '' : '';
      card.style.backgroundColor = active ? '' : '';
      card.className = card.className
        .replace(/border-violet-500\/\d+|border-black\/\d+/, active ? 'border-violet-500/40' : 'border-black/6')
        .replace(/bg-violet-500\/\[[\d.]+\]|bg-black\/\[[\d.]+\]/, active ? 'bg-violet-500/[0.06]' : 'bg-black/[0.01]');
      card.querySelector('.opacity-20')?.classList.toggle('opacity-20', !active);
      card.querySelector('.opacity-20')?.classList.toggle('opacity-40', active);
    });
    if (reasoningEl && ri.reasoning) {
      reasoningEl.textContent = ri.reasoning.slice(0, 30);
      reasoningEl.classList.remove('invisible');
    } else if (reasoningEl) {
      reasoningEl.classList.add('invisible');
    }

    // Render graph visualization
    renderGraphCanvas(data);
  }

  function renderGraphCanvas(data) {
    const canvas = document.getElementById('graph-canvas');
    if (!canvas) return;
    const gm = data.graph_metrics || {};
    const ri = data.routing_info || {};
    const nodeCount = Math.min(gm.node_count || 0, 24);
    const depth = gm.traversal_depth || 0;
    const source = gm.search_source || '';

    const RC = '#a78bfa', IC = '#fbbf24', CC = '#34d399';

    if (nodeCount === 0 || source !== 'graph_rag') {
      canvas.innerHTML = `<div class="flex flex-col items-center gap-2">
        <div class="flex items-center gap-1.5"><div class="h-2.5 w-2.5 rounded-full" style="background:${RC}"></div><div class="h-px w-6" style="background:${RC}33"></div><div class="h-2.5 w-2.5 rounded-full" style="background:${IC}"></div><div class="h-px w-6" style="background:${RC}33"></div><div class="h-2.5 w-2.5 rounded-full" style="background:${CC}"></div></div>
        <div class="flex gap-3 text-[9px] text-black/55 dark:text-white/50"><span style="color:${RC}">● 菜谱</span><span style="color:${IC}">● 食材</span><span style="color:${CC}">● 分类</span></div>
        <div class="text-[10px] text-black/45 dark:text-white/40">Neo4j · 362 菜谱 · 500+ 食材 · 3 跳推理</div>
      </div>`;
      return;
    }

    const COLORS = [RC, IC, CC];
    let html = '<div class="flex flex-col items-center gap-2">';
    html += '<div class="flex flex-wrap justify-center gap-1" style="max-width:200px">';
    for (let i = 0; i < nodeCount; i++) {
      const c = COLORS[i % 3];
      html += `<span class="inline-block rounded-full" style="width:8px;height:8px;background:${c};opacity:0.7"></span>`;
    }
    html += '</div>';
    html += `<div class="text-[10px] text-black/70 dark:text-white/70">${nodeCount} nodes · depth ${depth}</div>`;
    html += `<div class="flex gap-3 text-[9px]"><span style="color:${RC}">● 菜谱</span><span style="color:${IC}">● 食材</span><span style="color:${CC}">● 分类</span></div>`;
    html += '</div>';
    canvas.innerHTML = html;
  }

  graphragSendBtn.addEventListener('click', () => sendGraphragQuery(graphragInput.value));
  graphragInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendGraphragQuery(graphragInput.value);
    }
  });
</script>
