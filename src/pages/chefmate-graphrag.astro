---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ChefMate GraphRAG | Vincent Hu" description="图增强智能食谱问答系统 — GraphRAG 技术演示">
  <div class="mx-auto flex max-w-5xl flex-col gap-8">
    <!-- Header -->
    <div class="hero-panel animate-slide-enter overflow-hidden rounded-[2rem] border border-black/8 p-6 shadow-[0_24px_80px_rgba(15,23,42,0.08)] dark:border-white/10 dark:shadow-[0_24px_80px_rgba(0,0,0,0.28)] md:p-7">
      <div class="flex items-center gap-3 mb-3">
        <span class="inline-flex items-center gap-1.5 rounded-full border border-violet-500/20 bg-violet-500/8 px-2.5 py-0.5 text-xs font-mono tracking-[0.22em] text-violet-700 dark:text-violet-300">
          GraphRAG DEMO
        </span>
        <span class="text-xs opacity-35">Neo4j · Milvus · DeepSeek V4 · 智能路由</span>
      </div>
      <div class="grid gap-5 lg:grid-cols-[auto_1fr] lg:items-center">
        <h1 class="text-3xl font-bold font-condensed tracking-tight md:text-4xl shrink-0">
          ChefMate GraphRAG
        </h1>
        <div class="text-sm leading-6 opacity-55 lg:border-l lg:border-black/10 lg:pl-5 dark:lg:border-white/10">
          基于图增强检索的下一代食谱问答系统。<br class="hidden sm:block" />
          <span class="opacity-40 text-xs mt-1 block">🚧 后端开发中，前端演示已就绪</span>
        </div>
      </div>
    </div>

    <!-- Main: Chat + Right Panel -->
    <div class="grid gap-6 lg:grid-cols-[2fr_1fr] items-start">
      <!-- Left: Chat -->
      <div class="flex flex-col gap-4">
        <div class="flex flex-col gap-5 h-[480px] overflow-y-auto rounded-[1.75rem] border border-black/8 bg-white/52 p-6 dark:border-white/10 dark:bg-white/[0.03]">
          <div class="flex items-start gap-3">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-violet-500/15 text-base dark:bg-violet-500/20">🕸️</div>
            <div class="rounded-2xl rounded-tl-md bg-black/[0.03] px-4 py-3 text-sm leading-relaxed dark:bg-white/[0.05] msg-content">
              你好！我是 <strong>ChefMate GraphRAG</strong>，基于知识图谱的智能食谱助手。<br/>
              相比 RAG 版本，我能理解食材关系、发现相似菜品、进行多跳推理。<br/><br/>
              试试问我「<strong>哪些川菜用了鸡肉和花生</strong>」或「<strong>有没有类似宫保鸡丁但更简单的</strong>」。
            </div>
          </div>
        </div>

        <form class="flex gap-3 opacity-40 pointer-events-none">
          <input type="text" value="" placeholder="后端 GraphRAG 引擎开发中…" disabled
            class="flex-1 rounded-xl border border-black/8 bg-white/62 px-5 py-3 text-sm outline-none placeholder:opacity-35 disabled:opacity-30" />
          <button type="submit" disabled
            class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-violet-600 text-white shadow-lg disabled:opacity-30">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </form>
      </div>

      <!-- Right: Strategy + Metrics -->
      <div class="flex flex-col gap-5">
        <!-- Strategy Selector -->
        <div class="rounded-[1.75rem] border border-black/8 bg-white/52 p-5 dark:border-white/10 dark:bg-white/[0.03]">
          <h3 class="text-xs font-mono tracking-[0.18em] opacity-35 mb-4">STRATEGY</h3>
          <div class="space-y-2.5">
            <div class="flex items-center gap-3 rounded-xl border border-violet-500/20 bg-violet-500/[0.04] p-3">
              <span class="text-base">🔍</span>
              <div>
                <div class="text-xs font-medium opacity-70">传统混合检索</div>
                <div class="text-[10px] opacity-30">Milvus + BM25 + RRF</div>
              </div>
              <span class="ml-auto text-[10px] font-mono opacity-20">简单</span>
            </div>
            <div class="flex items-center gap-3 rounded-xl border border-violet-500/20 bg-violet-500/[0.04] p-3">
              <span class="text-base">🔄</span>
              <div>
                <div class="text-xs font-medium opacity-70">组合检索</div>
                <div class="text-[10px] opacity-30">传统 + 图 RAG</div>
              </div>
              <span class="ml-auto text-[10px] font-mono opacity-20">中等</span>
            </div>
            <div class="flex items-center gap-3 rounded-xl border border-violet-500/40 bg-violet-500/[0.08] p-3">
              <span class="text-base">🕸️</span>
              <div>
                <div class="text-xs font-medium opacity-70">图 RAG 检索</div>
                <div class="text-[10px] opacity-30">多跳推理 · 子图提取</div>
              </div>
              <span class="ml-auto text-[10px] font-mono opacity-20">复杂</span>
            </div>
          </div>
        </div>

        <!-- Knowledge Graph Preview -->
        <div class="rounded-[1.75rem] border border-black/8 bg-white/52 p-5 dark:border-white/10 dark:bg-white/[0.03]">
          <h3 class="text-xs font-mono tracking-[0.18em] opacity-35 mb-4">GRAPH</h3>
          <div class="rounded-xl border border-dashed border-black/10 bg-black/[0.01] px-4 py-5 dark:border-white/10 dark:bg-white/[0.01]">
            <div class="flex flex-col items-center gap-3">
              <div class="flex items-center gap-2">
                <div class="h-3 w-3 rounded-full bg-violet-400"></div>
                <div class="h-0.5 w-8 bg-violet-300/30"></div>
                <div class="h-3 w-3 rounded-full bg-amber-400"></div>
                <div class="h-0.5 w-8 bg-violet-300/30"></div>
                <div class="h-3 w-3 rounded-full bg-emerald-400"></div>
                <div class="h-0.5 w-8 bg-violet-300/30"></div>
                <div class="h-3 w-3 rounded-full bg-rose-400"></div>
              </div>
              <div class="flex gap-4 text-[10px] opacity-30">
                <span>菜谱</span><span>食材</span><span>步骤</span><span>分类</span>
              </div>
              <div class="text-[10px] opacity-20 mt-1">
                Neo4j · 362 菜谱 · 500+ 食材 · 3 跳推理
              </div>
            </div>
          </div>
        </div>

        <!-- Metrics -->
        <div id="metrics-panel" class="rounded-[1.75rem] border border-black/8 bg-white/52 p-5 dark:border-white/10 dark:bg-white/[0.03]">
          <h3 class="text-xs font-mono tracking-[0.18em] opacity-35 mb-4">RAG METRICS</h3>
          <div id="metrics-content" class="grid gap-3 grid-cols-2">
            <div class="rounded-xl border border-black/6 bg-black/[0.015] p-3 dark:border-white/8 dark:bg-white/[0.02]">
              <div class="text-[10px] opacity-35 mb-1">路由策略</div>
              <div class="text-sm font-medium opacity-25">—</div>
            </div>
            <div class="rounded-xl border border-black/6 bg-black/[0.015] p-3 dark:border-white/8 dark:bg-white/[0.02]">
              <div class="text-[10px] opacity-35 mb-1">图遍历深度</div>
              <div class="text-sm font-medium opacity-25">—</div>
            </div>
            <div class="rounded-xl border border-black/6 bg-black/[0.015] p-3 dark:border-white/8 dark:bg-white/[0.02]">
              <div class="text-[10px] opacity-35 mb-1">检索来源</div>
              <div class="text-sm font-medium opacity-25">—</div>
            </div>
            <div class="rounded-xl border border-black/6 bg-black/[0.015] p-3 dark:border-white/8 dark:bg-white/[0.02]">
              <div class="text-[10px] opacity-35 mb-1">子图节点</div>
              <div class="text-sm font-medium opacity-25">—</div>
            </div>
          </div>
        </div>

        <div class="rounded-xl border border-amber-500/20 bg-amber-500/[0.04] px-3 py-2.5 text-xs opacity-50">
          后端 GraphRAG 引擎开发中，接口就绪后接入
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .msg-content h1 { font-size: 1.1rem; font-weight: 700; margin: 0.6em 0 0.3em; }
  .msg-content h2 { font-size: 1rem; font-weight: 650; margin: 0.5em 0 0.25em; padding-bottom: 0.2em; border-bottom: 1px solid rgb(0 0 0 / 0.06); }
  .msg-content p { margin: 0.5em 0; }
  .msg-content strong { font-weight: 650; }
  .msg-content ul { padding-left: 1.5em; margin: 0.4em 0; }
  .msg-content li { margin: 0.25em 0; }
</style>
