---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ChefMate | Vincent Hu" description="智能食谱问答系统 — RAG 技术演示">
  <div class="mx-auto flex max-w-5xl flex-col gap-8">
    <!-- Header -->
    <div class="hero-panel animate-slide-enter overflow-hidden rounded-[2rem] border border-black/8 p-6 shadow-[0_24px_80px_rgba(15,23,42,0.08)] dark:border-white/10 dark:shadow-[0_24px_80px_rgba(0,0,0,0.28)] md:p-7">
      <div class="flex items-center gap-3 mb-3">
        <span class="inline-flex items-center gap-1.5 rounded-full border border-amber-500/20 bg-amber-500/8 px-2.5 py-0.5 text-xs font-mono tracking-[0.22em] text-amber-700 dark:text-amber-300">RAG DEMO</span>
        <span class="text-xs opacity-35">DeepSeek V4 · FAISS · BM25 混合检索</span>
      </div>
      <div class="grid gap-5 lg:grid-cols-[auto_1fr] lg:items-center">
        <h1 class="text-3xl font-bold font-condensed tracking-tight md:text-4xl shrink-0">ChefMate</h1>
        <div class="text-sm leading-6 opacity-55 lg:border-l lg:border-black/10 lg:pl-5 dark:lg:border-white/10">
          基于 RAG 的食谱问答系统，输入菜名获取分步烹饪指导。<br class="hidden sm:block" />
          <span class="opacity-40 text-xs mt-1 block">API 由笔者自费提供，请勿频繁调用。检索偶有偏差，答案仅供参考。</span>
        </div>
      </div>
    </div>

    <!-- Version Selector -->
    <div class="animate-slide-enter grid gap-4 md:grid-cols-2" style="animation-delay: 50ms;">
      <button id="tab-rag" class="version-tab group rounded-[1.4rem] border-2 border-amber-500/40 bg-amber-500/[0.06] p-5 cursor-pointer transition-all duration-200 hover:border-amber-500/60 hover:shadow-[0_8px_24px_rgba(245,158,11,0.12)]">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-xl">🔍</span>
          <div class="text-left">
            <div class="text-sm font-semibold opacity-80">ChefMate RAG</div>
            <div class="text-[11px] opacity-35">FAISS + BM25 混合检索</div>
          </div>
          <span class="ml-auto rounded-full bg-amber-500/20 px-2 py-0.5 text-[10px] font-mono text-amber-700 dark:text-amber-300">在线可用</span>
        </div>
        <p class="text-xs opacity-45 leading-relaxed text-left">基于向量检索的传统 RAG，支持查询路由、多轮对话、份量感知。</p>
      </button>
      <button id="tab-graphrag" class="version-tab group rounded-[1.4rem] border-2 border-transparent bg-black/[0.02] p-5 cursor-pointer transition-all duration-200 hover:border-violet-500/40 dark:bg-white/[0.02]">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-xl">🕸️</span>
          <div class="text-left">
            <div class="text-sm font-semibold opacity-80">ChefMate GraphRAG</div>
            <div class="text-[11px] opacity-35">Neo4j 知识图谱 + 智能路由</div>
          </div>
          <span class="ml-auto rounded-full bg-emerald-500/20 px-2 py-0.5 text-[10px] font-mono text-emerald-700 dark:text-emerald-300">在线可用</span>
        </div>
        <p class="text-xs opacity-45 leading-relaxed text-left">引入 Neo4j 图数据库，支持多跳推理、子图提取与三级降级策略。</p>
      </button>
    </div>

    <!-- RAG Demo (default) -->
    <div id="demo-rag">
    <div id="chefmate-app" class="animate-slide-enter" style="animation-delay: 100ms;">
      <div class="grid gap-6 lg:grid-cols-[2fr_1fr] items-start">
        <!-- Left: Chat area (2/3) -->
        <div class="flex flex-col gap-4">
          <div id="chat-messages" class="flex flex-col gap-5 h-[480px] overflow-y-auto rounded-[1.75rem] border border-black/8 bg-white/52 p-6 dark:border-white/10 dark:bg-white/[0.03]">
            <div class="flex items-start gap-3">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-amber-500/15 text-base dark:bg-amber-500/20">🧑‍🍳</div>
              <div class="rounded-2xl rounded-tl-md bg-black/[0.03] px-4 py-3 text-sm leading-relaxed dark:bg-white/[0.05] msg-content">
                你好！我是 <strong>ChefMate</strong>，你的智能食谱助手。<br/>试试问我「<strong>宫保鸡丁怎么做</strong>」或者「<strong>推荐两个素菜</strong>」吧。
      </div>
    </div>
    </div>

          <form id="chat-form" class="flex gap-3">
            <input
              id="chat-input"
              type="text"
              placeholder="输入你想做的菜，例如：宫保鸡丁怎么做"
              class="flex-1 rounded-xl border border-black/8 bg-white/62 px-5 py-3 text-sm outline-none transition-all duration-200 placeholder:opacity-35 focus:border-primary/40 focus:shadow-[0_0_0_3px_rgba(86,69,212,0.12)] dark:border-white/10 dark:bg-white/[0.04] dark:focus:border-primary-mist/40"
            />
            <button
              type="submit"
              class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-primary text-white shadow-lg transition-all duration-200 hover:bg-primary-dark hover:shadow-[0_4px_12px_rgba(86,69,212,0.3)] disabled:opacity-40"
              id="chat-send"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
          </form>
        </div>

        <!-- Right: Suggested queries + status indicator -->
        <div class="flex flex-col gap-4">
          <div class="h-[480px] flex flex-col rounded-[1.75rem] border border-black/8 bg-white/52 p-5 dark:border-white/10 dark:bg-white/[0.03]">
            <h3 class="text-xs font-mono tracking-[0.18em] opacity-35 mb-3 shrink-0">PROMPTS</h3>
            <div class="flex-1 space-y-2.5 overflow-hidden">
              <button class="prompt-chip w-full text-left rounded-xl border border-black/6 bg-black/[0.015] px-3 py-2.5 text-[11px] leading-snug transition-all duration-150 hover:border-primary/30 hover:bg-primary/[0.03] dark:border-white/8 dark:bg-white/[0.02] dark:hover:border-primary-mist/30 dark:hover:bg-primary/[0.05]" data-query="宫保鸡丁怎么做">
                <span class="font-medium opacity-70">宫保鸡丁怎么做</span>
                <span class="opacity-30 ml-1.5">步骤教学</span>
              </button>
              <button class="prompt-chip w-full text-left rounded-xl border border-black/6 bg-black/[0.015] px-3 py-2.5 text-[11px] leading-snug transition-all duration-150 hover:border-primary/30 hover:bg-primary/[0.03] dark:border-white/8 dark:bg-white/[0.02] dark:hover:border-primary-mist/30 dark:hover:bg-primary/[0.05]" data-query="推荐几个素菜">
                <span class="font-medium opacity-70">推荐几个素菜</span>
                <span class="opacity-30 ml-1.5">列表推荐</span>
              </button>
              <button class="prompt-chip w-full text-left rounded-xl border border-black/6 bg-black/[0.015] px-3 py-2.5 text-[11px] leading-snug transition-all duration-150 hover:border-primary/30 hover:bg-primary/[0.03] dark:border-white/8 dark:bg-white/[0.02] dark:hover:border-primary-mist/30 dark:hover:bg-primary/[0.05]" data-query="推荐3个简单的素菜，适合5个人吃">
                <span class="font-medium opacity-70">推荐3个简单的素菜，适合5个人吃</span>
                <span class="opacity-30 ml-1.5">份量感知</span>
              </button>
              <button class="prompt-chip w-full text-left rounded-xl border border-black/6 bg-black/[0.015] px-3 py-2.5 text-[11px] leading-snug transition-all duration-150 hover:border-primary/30 hover:bg-primary/[0.03] dark:border-white/8 dark:bg-white/[0.02] dark:hover:border-primary-mist/30 dark:hover:bg-primary/[0.05]" data-query="用鸡蛋能做什么菜">
                <span class="font-medium opacity-70">用鸡蛋能做什么菜</span>
                <span class="opacity-30 ml-1.5">食材查询</span>
              </button>
              <button class="prompt-chip w-full text-left rounded-xl border border-black/6 bg-black/[0.015] px-3 py-2.5 text-[11px] leading-snug transition-all duration-150 hover:border-primary/30 hover:bg-primary/[0.03] dark:border-white/8 dark:bg-white/[0.02] dark:hover:border-primary-mist/30 dark:hover:bg-primary/[0.05]" data-query="夏天适合吃什么菜">
                <span class="font-medium opacity-70">夏天适合吃什么菜</span>
                <span class="opacity-30 ml-1.5">场景推荐</span>
              </button>
              <button class="prompt-chip w-full text-left rounded-xl border border-black/6 bg-black/[0.015] px-3 py-2.5 text-[11px] leading-snug transition-all duration-150 hover:border-primary/30 hover:bg-primary/[0.03] dark:border-white/8 dark:bg-white/[0.02] dark:hover:border-primary-mist/30 dark:hover:bg-primary/[0.05]" data-query="没有淀粉可以用什么代替">
                <span class="font-medium opacity-70">没有淀粉可以用什么代替</span>
                <span class="opacity-30 ml-1.5">通用问答</span>
              </button>
              <button class="prompt-chip w-full text-left rounded-xl border border-black/6 bg-black/[0.015] px-3 py-2.5 text-[11px] leading-snug transition-all duration-150 hover:border-primary/30 hover:bg-primary/[0.03] dark:border-white/8 dark:bg-white/[0.02] dark:hover:border-primary-mist/30 dark:hover:bg-primary/[0.05]" data-query="适合两个人吃的菜">
                <span class="font-medium opacity-70">适合两个人吃的菜</span>
                <span class="opacity-30 ml-1.5">小份量</span>
              </button>
              <button class="prompt-chip w-full text-left rounded-xl border border-black/6 bg-black/[0.015] px-3 py-2.5 text-[11px] leading-snug transition-all duration-150 hover:border-primary/30 hover:bg-primary/[0.03] dark:border-white/8 dark:bg-white/[0.02] dark:hover:border-primary-mist/30 dark:hover:bg-primary/[0.05]" data-query="推荐几个下饭菜">
                <span class="font-medium opacity-70">推荐几个下饭菜</span>
                <span class="opacity-30 ml-1.5">场景推荐</span>
              </button>
            </div>
          </div>

          <div id="metrics-status" class="rounded-xl border border-black/10 bg-black/[0.03] px-3 py-3 text-xs leading-relaxed opacity-55 dark:border-white/10 dark:bg-white/[0.04]">
            <span id="status-text">检索分析结果在页面下方生成</span>
          </div>
        </div>
      </div>

      <!-- Metrics panel: full-width below both columns -->
      <div id="metrics-panel" class="mt-6 rounded-[1.75rem] border border-black/8 bg-white/52 p-5 dark:border-white/10 dark:bg-white/[0.03]">
        <h3 class="text-xs font-mono tracking-[0.18em] opacity-35 mb-4">RAG METRICS</h3>
        <div id="metrics-content" class="grid gap-4 lg:grid-cols-3">
          <div class="text-sm opacity-40 col-span-full">等待查询...</div>
        </div>
      </div>
    </div>
  </div>

  <!-- GraphRAG Demo -->
  <div id="demo-graphrag" style="display:none">
    <div class="grid gap-4 lg:grid-cols-[2fr_1fr] items-start">
      <div class="flex flex-col gap-4">
        <div class="flex flex-col gap-5 h-[480px] overflow-y-auto rounded-[1.75rem] border border-black/8 bg-white/52 p-6 dark:border-white/10 dark:bg-white/[0.03]">
          <div class="flex items-start gap-3">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-violet-500/15 text-base dark:bg-violet-500/20">🕸️</div>
            <div class="rounded-2xl rounded-tl-md bg-black/[0.03] px-4 py-3 text-sm leading-relaxed dark:bg-white/[0.05] msg-content">
              你好！我是 <strong>ChefMate GraphRAG</strong>，基于知识图谱的智能食谱助手。<br/>
              我能理解食材关系、发现相似菜品、进行多跳推理。<br/><br/>
              试试问我「<strong>哪些川菜用了鸡肉和花生</strong>」或「<strong>有没有类似宫保鸡丁但更简单的</strong>」。
            </div>
          </div>
        </div>
        <form id="graphrag-form" class="flex gap-3" onsubmit="return false;">
          <input id="graphrag-input" type="text" placeholder="试试多跳查询：「鸡肉配什么蔬菜」" class="flex-1 rounded-xl border border-black/8 bg-white/62 px-5 py-3 text-sm outline-none focus:border-violet-500/40 transition-colors" />
          <button id="graphrag-send-btn" class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-violet-600 text-white hover:bg-violet-700 transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </form>
      </div>
      <div class="flex flex-col gap-4">
        <div class="h-[480px] flex flex-col rounded-[1.75rem] border border-black/8 bg-white/52 p-5 dark:border-white/10 dark:bg-white/[0.03]">
          <h3 class="text-xs font-mono tracking-[0.18em] text-black/55 dark:text-white/50 mb-3 shrink-0">PROMPTS <span class="info-dot inline-flex" data-title="点击示例查询直接发送到 GraphRAG 引擎。包含食材搭配、相似菜品、食材替代等图谱推理场景"></span></h3>
          <div class="flex-1 space-y-2.5 overflow-hidden">
            <button class="prompt-chip w-full text-left rounded-xl border border-black/6 bg-black/[0.015] px-3 py-2.5 text-[11px] leading-snug transition-all duration-150 hover:border-violet-500/30 hover:bg-violet-500/[0.03] dark:border-white/8 dark:bg-white/[0.02] dark:hover:border-violet-500/30 dark:hover:bg-violet-500/[0.05]" data-query="鸡肉配什么蔬菜">
              <span class="font-medium opacity-70">鸡肉配什么蔬菜</span>
              <span class="opacity-30 ml-1.5">食材搭配</span>
            </button>
            <button class="prompt-chip w-full text-left rounded-xl border border-black/6 bg-black/[0.015] px-3 py-2.5 text-[11px] leading-snug transition-all duration-150 hover:border-violet-500/30 hover:bg-violet-500/[0.03] dark:border-white/8 dark:bg-white/[0.02] dark:hover:border-violet-500/30 dark:hover:bg-violet-500/[0.05]" data-query="和宫保鸡丁类似的菜">
              <span class="font-medium opacity-70">和宫保鸡丁类似的菜</span>
              <span class="opacity-30 ml-1.5">相似查询</span>
            </button>
            <button class="prompt-chip w-full text-left rounded-xl border border-black/6 bg-black/[0.015] px-3 py-2.5 text-[11px] leading-snug transition-all duration-150 hover:border-violet-500/30 hover:bg-violet-500/[0.03] dark:border-white/8 dark:bg-white/[0.02] dark:hover:border-violet-500/30 dark:hover:bg-violet-500/[0.05]" data-query="土豆能替代什么食材">
              <span class="font-medium opacity-70">土豆能替代什么食材</span>
              <span class="opacity-30 ml-1.5">食材替代</span>
            </button>
            <button class="prompt-chip w-full text-left rounded-xl border border-black/6 bg-black/[0.015] px-3 py-2.5 text-[11px] leading-snug transition-all duration-150 hover:border-violet-500/30 hover:bg-violet-500/[0.03] dark:border-white/8 dark:bg-white/[0.02] dark:hover:border-violet-500/30 dark:hover:bg-violet-500/[0.05]" data-query="川菜有哪些用了花椒的菜">
              <span class="font-medium opacity-70">川菜有哪些用了花椒的菜</span>
              <span class="opacity-30 ml-1.5">多条件查询</span>
            </button>
            <button class="prompt-chip w-full text-left rounded-xl border border-black/6 bg-black/[0.015] px-3 py-2.5 text-[11px] leading-snug transition-all duration-150 hover:border-violet-500/30 hover:bg-violet-500/[0.03] dark:border-white/8 dark:bg-white/[0.02] dark:hover:border-violet-500/30 dark:hover:bg-violet-500/[0.05]" data-query="大葱可以和什么一起炒">
              <span class="font-medium opacity-70">大葱可以和什么一起炒</span>
              <span class="opacity-30 ml-1.5">食材搭配</span>
            </button>
            <button class="prompt-chip w-full text-left rounded-xl border border-black/6 bg-black/[0.015] px-3 py-2.5 text-[11px] leading-snug transition-all duration-150 hover:border-violet-500/30 hover:bg-violet-500/[0.03] dark:border-white/8 dark:bg-white/[0.02] dark:hover:border-violet-500/30 dark:hover:bg-violet-500/[0.05]" data-query="什么菜用了牛肉和土豆">
              <span class="font-medium opacity-70">什么菜用了牛肉和土豆</span>
              <span class="opacity-30 ml-1.5">多条件查询</span>
            </button>
            <button class="prompt-chip w-full text-left rounded-xl border border-black/6 bg-black/[0.015] px-3 py-2.5 text-[11px] leading-snug transition-all duration-150 hover:border-violet-500/30 hover:bg-violet-500/[0.03] dark:border-white/8 dark:bg-white/[0.02] dark:hover:border-violet-500/30 dark:hover:bg-violet-500/[0.05]" data-query="推荐一些难度较高的菜">
              <span class="font-medium opacity-70">推荐一些难度较高的菜</span>
              <span class="opacity-30 ml-1.5">条件推荐</span>
            </button>
            <button class="prompt-chip w-full text-left rounded-xl border border-black/6 bg-black/[0.015] px-3 py-2.5 text-[11px] leading-snug transition-all duration-150 hover:border-violet-500/30 hover:bg-violet-500/[0.03] dark:border-white/8 dark:bg-white/[0.02] dark:hover:border-violet-500/30 dark:hover:bg-violet-500/[0.05]" data-query="用花椒做的菜有哪些">
              <span class="font-medium opacity-70">用花椒做的菜有哪些</span>
              <span class="opacity-30 ml-1.5">反向查询</span>
            </button>
          </div>
        </div>
        <div id="graphrag-status" class="rounded-xl border border-black/10 bg-black/[0.03] px-3 py-3 text-xs leading-relaxed opacity-55 dark:border-white/10 dark:bg-white/[0.04]">
          <span id="graphrag-status-text">检索分析结果在页面下方生成</span>
        </div>
      </div>
    </div>
    <!-- Strategy: full-width, horizontal 3-column -->
    <div class="mt-5 rounded-[1.75rem] border border-black/8 bg-white/52 p-5 dark:border-white/10 dark:bg-white/[0.03]">
      <div class="flex items-center gap-1 mb-3">
        <h3 class="text-xs font-mono tracking-[0.18em] text-black/55 dark:text-white/50">STRATEGY</h3>
        <span class="info-dot inline-flex" data-title="系统根据查询类型自动选择的检索策略。简单查询走传统混合检索（Milvus+BM25），关系推理走图RAG（Neo4j多跳遍历），复杂查询走组合策略"></span>
      </div>
      <div class="grid gap-3 lg:grid-cols-3">
        <div data-strategy="hybrid_traditional" class="flex items-center gap-3 rounded-xl border border-black/6 bg-black/[0.01] p-3 transition-all duration-200"><span class="text-base">🔍</span><div><div class="text-xs font-medium opacity-70">传统混合检索</div><div class="text-[10px] opacity-30">Milvus + BM25 + RRF</div></div><span class="ml-auto text-[10px] font-mono opacity-30">简单</span><span class="info-dot inline-flex ml-1" data-title="仅使用向量+BM25关键词匹配，不涉及图数据库查询。适合菜谱搜索、做法指导、推荐查询。延迟低、结果稳定"></span></div>
        <div data-strategy="combined" class="flex items-center gap-3 rounded-xl border border-black/6 bg-black/[0.01] p-3 transition-all duration-200"><span class="text-base">🔄</span><div><div class="text-xs font-medium opacity-70">组合检索</div><div class="text-[10px] opacity-30">传统 + 图 RAG</div></div><span class="ml-auto text-[10px] font-mono opacity-30">中等</span><span class="info-dot inline-flex ml-1" data-title="同时执行传统混合检索和图RAG检索，通过RRF算法融合结果。适合多条件查询（如「哪些菜用了土豆又用了猪肉」）"></span></div>
        <div data-strategy="graph_rag" class="flex items-center gap-3 rounded-xl border border-black/6 bg-black/[0.01] p-3 transition-all duration-200"><span class="text-base">🕸️</span><div><div class="text-xs font-medium opacity-70">图 RAG 检索</div><div class="text-[10px] opacity-30">多跳推理 · 子图提取</div></div><span id="gs-reasoning" class="ml-auto text-[10px] font-mono opacity-20 invisible"></span><span class="info-dot inline-flex ml-1" data-title="在图数据库Neo4j中执行多跳遍历和子图提取，利用实体关系网络进行推理。适合食材搭配、食材替代、相似菜品等需要关系推理的查询"></span></div>
      </div>
    </div>
    <!-- Metrics below, full-width -->
    <div class="mt-5 rounded-[1.75rem] border border-black/8 bg-white/52 p-5 dark:border-white/10 dark:bg-white/[0.03]">
      <h3 class="text-xs font-mono tracking-[0.18em] text-black/55 dark:text-white/50 mb-3">RAG METRICS</h3>
      <div class="grid gap-3 lg:grid-cols-4">
        <div class="rounded-xl border border-black/6 bg-black/[0.015] p-3 dark:border-white/8 dark:bg-white/[0.02]"><div class="text-[10px] text-black/65 dark:text-white/60 mb-1">路由策略 <span class="info-dot inline-flex" data-title="本次查询实际使用的检索策略：hybrid_traditional=传统混合检索，graph_rag=图RAG检索，combined=组合策略，greeting=问候"></span></div><div id="gm-route-strategy" class="text-sm font-medium text-black/80 dark:text-white/80">—</div></div>
        <div class="rounded-xl border border-black/6 bg-black/[0.015] p-3 dark:border-white/8 dark:bg-white/[0.02]"><div class="text-[10px] text-black/65 dark:text-white/60 mb-1">检索来源 <span class="info-dot inline-flex" data-title="结果的来源：milvus=向量检索，bm25=关键词匹配，graph_rag=图数据库遍历，combined=融合结果"></span></div><div id="gm-search-source" class="text-sm font-medium text-black/80 dark:text-white/80">—</div></div>
        <div class="rounded-xl border border-black/6 bg-black/[0.015] p-3 dark:border-white/8 dark:bg-white/[0.02]"><div class="text-[10px] text-black/65 dark:text-white/60 mb-1">检索数量 <span class="info-dot inline-flex" data-title="从知识库中检索到的相关文档/路径数量。数量多表示查询覆盖范围广，但也可能引入噪声"></span></div><div id="gm-retrieval-count" class="text-sm font-medium text-black/80 dark:text-white/80">—</div></div>
        <div class="rounded-xl border border-black/6 bg-black/[0.015] p-3 dark:border-white/8 dark:bg-white/[0.02]"><div class="text-[10px] text-black/65 dark:text-white/60 mb-1">延迟 <span class="info-dot inline-flex" data-title="端到端的处理时间（从接收查询到返回回答），包含检索+LLM生成。简单查询约2-5s，图谱查询约5-8s"></span></div><div id="gm-latency" class="text-sm font-medium text-black/80 dark:text-white/80">—</div></div>
        <div class="rounded-xl border border-black/6 bg-black/[0.015] p-3 dark:border-white/8 dark:bg-white/[0.02]"><div class="text-[10px] text-black/65 dark:text-white/60 mb-1">子图节点 <span class="info-dot inline-flex" data-title="图RAG在Neo4j中遍历到的节点数量。节点越多表示知识网络中与查询相关的实体越丰富"></span></div><div id="gm-node-count" class="text-sm font-medium text-black/80 dark:text-white/80">—</div></div>
        <div class="rounded-xl border border-black/6 bg-black/[0.015] p-3 dark:border-white/8 dark:bg-white/[0.02]"><div class="text-[10px] text-black/65 dark:text-white/60 mb-1">遍历深度 <span class="info-dot inline-flex" data-title="图遍历的最大跳数。深度=1表示直接邻居，深度=3表示通过3跳关系链找到的隐含关联"></span></div><div id="gm-depth" class="text-sm font-medium text-black/80 dark:text-white/80">—</div></div>
        <div class="rounded-xl border border-black/6 bg-black/[0.015] p-3 dark:border-white/8 dark:bg-white/[0.02]"><div class="text-[10px] text-black/65 dark:text-white/60 mb-1">置信度 <span class="info-dot inline-flex" data-title="检索结果与查询的相关性综合评分（0-100%）。基于检索分数+路径评分计算"></span></div><div id="gm-confidence" class="text-sm font-medium text-black/80 dark:text-white/80">—</div></div>
        <div class="rounded-xl border border-black/6 bg-black/[0.015] p-3 dark:border-white/8 dark:bg-white/[0.02]"><div class="text-[10px] text-black/65 dark:text-white/60 mb-1">关系密集度 <span class="info-dot inline-flex" data-title="查询对实体间关系的依赖程度（0-1）。越高表示越需要图谱推理，越低表示更偏向简单信息查找"></span></div><div id="gm-intensity" class="text-sm font-medium text-black/80 dark:text-white/80">—</div></div>
      </div>
    </div>
  </div>
</BaseLayout>

